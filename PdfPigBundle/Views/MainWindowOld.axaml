<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="80" d:DesignHeight="40"
        x:Class="PdfPigBundle.Views.MainWindowOld"
        Title="PdfPigBundle"
        Width="400"
        Height="400">

    <StackPanel Margin="10">
        <Button Content="确定"
            Width="80"
            Height="30"
            HorizontalAlignment="Center"
            Click="OnOkClickAsync" />
         <TextBlock Name="StatusText" Text="就绪" />
        <ProgressBar Name="ProgressBar" Minimum="0" Maximum="100" Value="0" Height="20" />
    </StackPanel>

</Window>
